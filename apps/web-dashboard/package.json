{
    "name": "squadeasy-web-dashboard",
    "type": "module",
    "scripts": {
        "build": "vite build && node ./scripts/copy-spa-fallback.mjs",
        "dev": "vite",
        "generate-client": "openapi-typescript https://woyken.github.io/squadeasy-api/openapi.SquadEasyApi.yaml -o ./src/api/squadEasyApi.d.ts",
        "generate-tracker-client": "openapi-typescript http://localhost:3000/openapi.json -o ./src/api/trackerServerApi.d.ts",
        "serve": "vite preview",
        "start": "vite preview",
        "tsc": "tsc --noEmit"
    },
    "dependencies": {
        "@solidjs/meta": "^0.29.4",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/solid-form": "^1.11.3",
        "@tanstack/solid-query": "^5.77.1",
        "@tanstack/solid-router": "^1.120.10",
        "@tanstack/solid-router-devtools": "^1.120.10",
        "echarts": "^5.6.0",
        "jszip": "^3.10.1",
        "openapi-fetch": "^0.14.0",
        "solid-js": "^1.9.12",
        "valibot": "^1.1.0"
    },
    "engines": {
        "node": ">=22"
    },
    "devDependencies": {
        "@tanstack/router-plugin": "^1.120.10",
        "@total-typescript/ts-reset": "^0.6.1",
        "autoprefixer": "^10.4.21",
        "openapi-typescript": "^6.7.6",
        "postcss": "^8.5.9",
        "tailwindcss": "^4.2.2",
        "typescript": "^6.0.2",
        "vite": "^8.0.8",
        "vite-plugin-solid": "^2.11.12"
    }
}
